{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/explore",     "destination": "/explore.html" },
    { "source": "/squads",      "destination": "/squads.html" },
    { "source": "/marketplace", "destination": "/marketplace.html" },
    { "source": "/squad",       "destination": "/squad.html" },
    { "source": "/product",     "destination": "/product.html" },
    { "source": "/profile",     "destination": "/profile.html" },
    { "source": "/login",       "destination": "/login.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",         "value": "DENY" },
        { "key": "X-XSS-Protection",        "value": "1; mode=block" },
        { "key": "Referrer-Policy",         "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }]
    },
    {
      "source": "/js/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=604800" }]
    }
  ]
}
